{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=RestaurantAppDb;Trusted_Connection=True;MultipleActiveResultSets=true;Max Pool Size=100;Min Pool Size=10;"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_ENV_VARIABLE_IN_PRODUCTION",
    "Issuer": "RestaurantApp",
    "Audience": "RestaurantAppUsers",
    "Comment": "In production, set JWT_SECRET_KEY environment variable. Development uses appsettings.Development.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "Smtp": {
    "Server": "smtp.mailtrap.io",
    "Port": 587,
    "SenderName": "Restaurant App",
    "SenderEmail": "no-reply@restaurantapp.com",
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_PASSWORD",
    "EnableSsl": true
  }
}
